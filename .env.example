# --- LibreChat connection (the normal path: chatouille, your org's webui) ---

# the URL you log into in your browser, e.g. https://chatouille.intra
LIBRECHAT_URL=

# label of the model in LibreChat's dropdown (e.g. "qwen-32b")
# leave blank — login.py will print suggested values after you authenticate.
LIBRECHAT_MODEL=

# the body field — for built-in providers same as the URL path (e.g. "openAI"),
# for custom providers it's the display name from librechat.yaml (e.g. "ollama")
LIBRECHAT_ENDPOINT=

# schema family for parsing — "openAI" for any custom OpenAI-compatible endpoint;
# leave blank for built-in providers (openAI, anthropic, google, ...)
LIBRECHAT_ENDPOINT_TYPE=

# --- session storage ---
# auth file written by login commands (relative to ~/.config/cli-agent)
SESSION_FILE=session.json

# --- agent behavior (optional, override CLI defaults) ---
# permission level when not overridden by --mode/--yolo flag.
# safe (default) | auto-edit | yolo
# CLI_AGENT_MODE=safe

# re-inject a tool-use reminder every N user turns (0 = off, default).
# bump to 3-5 only if your model drifts into bash-block explanations.
# CLI_AGENT_REMINDER_EVERY=0

# --- direct OpenAI-compatible endpoint (only for local testing without LibreChat) ---
# if both LIBRECHAT_URL and OPENAI_BASE_URL are set, LIBRECHAT_URL wins.
OPENAI_BASE_URL=
OPENAI_API_KEY=dummy
AGENT_MODEL=qwen2.5:3b
